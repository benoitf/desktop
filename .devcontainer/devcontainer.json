{
    "name": "Podman Desktop",
    "build": {
        "dockerfile": "Containerfile"
    },
    // do not use root
    "containerUser": "podman-desktop",
    // Add the IDs of extensions you want installed when the container is created.
    "extensions": [
        "svelte.svelte-vscode",
        "bradlc.vscode-tailwindcss"
    ],
    "features": {
    },
    "runArgs": [
        "--cap-add=sys_admin",
        "--security-opt",
        "seccomp=unconfined",
        "--device",
        "/dev/fuse",
        "--security-opt",
        "label=disable",
        "--security-opt",
        "apparmor=unconfined",
        "--memory-swap=6g",
        "--memory=4g"
   ],
   "postStartCommand": "/entrypoint.sh",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "workspaceFolder": "/workspace",
    "onCreateCommand": "yarn",
    "updateContentCommand": "yarn",
    "portsAttributes": {
		"8080": {
			"label": "vnc",
            "onAutoForward": "openBrowser"
		}
	},

}